{
  "name": "chiro-erp-issue-pipeline-orchestrator",
  "version": "1.0.0",
  "description": "MCP Server for automated issue-to-PR pipeline with role-based AI agents",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
