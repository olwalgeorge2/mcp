# Environment Variables for Issue Pipeline Orchestrator

# ==============================================================================
# GitHub Configuration
# ==============================================================================
# Personal Access Token with repo permissions
# Get yours at: https://github.com/settings/tokens/new
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_OWNER=your-username-or-org
GITHUB_REPO=mvp

# ==============================================================================
# OpenAI Configuration
# ==============================================================================
# Get your API key at: https://platform.openai.com/api-keys
# Free tier includes $20 credit for new accounts
OPENAI_API_KEY=your_openai_api_key_here

# Model Selection:
# - gpt-4-turbo-preview: Best quality, higher cost (~$0.01/1K tokens)
# - gpt-4: Stable, reliable, moderate cost
# - gpt-3.5-turbo: Fast, cost-effective (~$0.0015/1K tokens)
OPENAI_MODEL=gpt-4-turbo-preview

# Optional: Set maximum tokens for API calls (helps control costs)
# OPENAI_MAX_TOKENS=4000

# Optional: Temperature override (0.0-1.0, lower = more deterministic)
# OPENAI_TEMPERATURE=0.3

# ==============================================================================
# Agent Configuration
# ==============================================================================
# Enable automatic implementation without human approval
ENABLE_AUTO_IMPLEMENT=true

# Maximum complexity score (1-10) for auto-implementation
# Issues above this score will require human approval
MAX_COMPLEXITY_SCORE=7

# Require human approval for all implementations
REQUIRE_HUMAN_APPROVAL=false

# ==============================================================================
# GitHub MCP Server Integration (Optional)
# ==============================================================================
# Enable GitHub MCP server for enhanced GitHub operations
# Install: npm install @modelcontextprotocol/server-github
USE_GITHUB_MCP_SERVER=false

# GitHub MCP Server path (if using local installation)
# GITHUB_MCP_SERVER_PATH=./node_modules/@modelcontextprotocol/server-github/dist/index.js

# ==============================================================================
# Pipeline Configuration
# ==============================================================================
AUTO_CREATE_BRANCH=true
AUTO_CREATE_PR=true
AUTO_RUN_TESTS=true

# ==============================================================================
# Cost Tracking & Monitoring (Optional)
# ==============================================================================
# Enable cost tracking for OpenAI API usage
ENABLE_COST_TRACKING=true

# Set monthly budget limit in USD (warning only, doesn't block)
# MONTHLY_BUDGET_LIMIT=50

# Log API usage to file
# COST_LOG_FILE=./logs/api-costs.json

# ==============================================================================
# Privacy / Offline Mode
# ==============================================================================
OFFLINE_MODE=false
STATE_STORE_PATH=./pipeline-state.json

# ==============================================================================
# Logging & Debugging
# ==============================================================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Enable verbose agent logging
VERBOSE_AGENT_LOGS=false
